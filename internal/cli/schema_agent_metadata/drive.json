    "drive copy": {
      "agent_summary": "将指定节点复制到目标文件夹。",
      "agent_summary_source": "mcp-tools-list+cli-registry@4574f7022c32",
      "use_when": [
        "── 场景 A: 复制到知识库空间根目录 ──",
        "── 场景 C: 复制到钉盘子文件夹 ──",
        "── 场景 默认: 复制/移动到「我的文件」根目录 ──",
        "复制文件/移动文件/搬到/移到"
      ],
      "examples": [
        "dws drive copy --node \u003cID\u003e [--folder \u003cTARGET\u003e] [--workspace \u003cWS\u003e]",
        "dws drive copy --node \u003c源文件dentryUuid\u003e --folder \u003c我的文件rootFolderId\u003e --format json"
      ],
      "reviewed": false,
      "source_refs": [
        "internal/cli/schema_mcp_metadata.json#tools.drive.copy_document",
        "skills/mono/references/products/drive.md"
      ]
    },
    "drive delete": {
      "agent_summary": "将指定节点移入回收站，30 天内可从回收站恢复，超过 30 天将被永久删除。",
      "agent_summary_source": "mcp-tools-list+cli-registry@4574f7022c32",
      "use_when": [
        "删除文件/删除文件夹/移到回收站",
        "正确流程：1.向用户展示\"即将删除「文件名」到回收站\" → 2.等用户确认 → 3.执行下面命令"
      ],
      "effect": "destructive",
      "effect_source": "agent-hint",
      "risk": "high",
      "confirmation": "user_required",
      "examples": [
        "dws drive delete --node \u003cdentryUuid\u003e --format json    # 查询 fileId: dws drive list",
        "dws drive delete --node \u003cdentryUuid\u003e --yes --format json"
      ],
      "reviewed": false,
      "source_refs": [
        "internal/cli/schema_mcp_metadata.json#tools.drive.delete_document",
        "skills/mono/references/products/drive.md",
        "skills/mono/schema-hints/destructive-safety.json"
      ]
    },
