{
  "version": 1,
  "source": {
    "kind": "explicit",
    "name": "dws-agent-hints/ding",
    "repository": "DingTalk-Real-AI/dingtalk-workspace-cli",
    "channel": "open-source"
  },
  "tools": {
    "ding.recall_ding_message": {
      "use_when": [
        "撤回 DING",
        "撤回DING；撤回 DING 消息",
        "机器人身份: 撤回"
      ],
      "avoid_when": [
        "要“发送 DING 消息（应用内 / 短信 / 电话）”请改用 dws ding message send"
      ],
      "examples": [
        "dws ding message recall --robot-code <ROBOT_CODE> --id <OPEN_DING_ID>",
        "dws ding message recall --robot-code <ROBOT_CODE> --id <OPEN_DING_ID> --format json"
      ],
      "interface_mode": "mcp",
      "availability": "available",
      "effect": "write",
      "confirmation": "not_required",
      "risk": "medium",
      "reviewed": true
    },
    "ding.send_ding_message": {
      "use_when": [
        "DING 一下/紧急通知/电话提醒",
        "发DING/DING通知；发送 DING 消息",
        "机器人身份: 应用内 DING (免费)",
        "机器人身份: 电话 DING (紧急, 有成本!)"
      ],
      "avoid_when": [
        "要“撤回 DING 消息”请改用 dws ding message recall"
      ],
      "examples": [
        "dws ding message send --robot-code <ROBOT_CODE> --users <USER_ID_1>,<USER_ID_2> --content \"请查看\"",
        "dws ding message send --robot-code <ROBOT_CODE> --type app --users userId1,userId2 --content \"请查看\" --format json"
      ],
      "interface_mode": "mcp",
      "availability": "available"
    }
  }
}
