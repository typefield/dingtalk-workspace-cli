{
  "_version": "2.0.0",
  "_description": "钉钉文档 JSONML 严格校验 schema。校验器为通用递归解释器，不含业务逻辑。",
  "tags": {
    "root": {
      "allowed_children": [
        "p",
        "h1",
        "h2",
        "h3",
        "h4",
        "h5",
        "h6",
        "hr",
        "table",
        "code",
        "container",
        "embed",
        "onlineVideo",
        "card",
        "toc",
        "refblock",
        "cangjie-voidblock",
        "cangjie-container"
      ],
      "attrs": {
        "uuid": {
          "type": "string"
        },
        "sectPr": {
          "type": "object"
        },
        "theme": {
          "type": "object"
        },
        "userData": {
          "type": "object"
        },
        "background": {
          "type": "union",
          "types": [
            "string",
            "object",
            "null"
          ]
        }
      },
      "description": "文档根节点，包含所有块级元素"
    },
    "p": {
      "description": "段落元素，支持 jc(对齐)、list(列表属性)、spacing(间距) 等属性",
      "allowed_children": [
        "span",
        "img",
        "a",
        "tag",
        "inlineCode",
        "br",
        "cangjie-textinline",
        "cangjie-voidinline"
      ],
      "attrs": {
        "uuid": {
          "type": "string"
        },
        "jc": {
          "type": "enum",
          "values": [
            "left",
            "center",
            "right",
            "both",
            "distribute",
            "justify"
          ]
        },
        "blockquote": {
          "type": "boolean"
        },
        "ind": {
          "type": "object",
          "fields": {
            "left": {
              "type": "number"
            },
            "start": {
              "type": "number"
            },
            "leftChars": {
              "type": "number"
            },
            "right": {
              "type": "number"
            },
            "end": {
              "type": "number"
            },
            "rightChars": {
              "type": "number"
            },
            "hanging": {
              "type": "number"
            },
            "hangingChars": {
              "type": "number"
            },
            "firstLine": {
              "type": "number"
            },
            "firstLineChars": {
              "type": "number"
            }
          }
        },
        "list": {
          "type": "object",
          "fields": {
            "listId": {
              "type": "string"
            },
            "level": {
              "type": "number",
              "min": 0,
              "max": 9,
              "description": "0-indexed nesting depth; top-level items should use 0"
            },
            "isOrdered": {
              "type": "boolean"
            },
            "isTaskList": {
              "type": "boolean"
            },
            "isChecked": {
              "type": "boolean"
            },
            "hideSymbol": {
              "type": "boolean"
            },
            "listStyle": {
              "type": "object"
            },
            "listStyleType": {
              "type": "string"
            },
            "symbolStyle": {
              "type": "object"
            },
            "start": {
              "type": "number",
              "min": 1
            },
            "extraData": {
              "type": "object"
            }
          }
        },
        "spacing": {
          "type": "object",
          "fields": {
            "line": {
              "type": "number"
            },
            "before": {
              "type": "union",
              "types": [
                "number",
                "string",
                "null"
              ]
            },
            "beforeLines": {
              "type": "number"
            },
            "beforeAutospacing": {
              "type": "boolean"
            },
            "after": {
              "type": "union",
              "types": [
                "number",
                "string",
                "null"
              ]
            },
            "afterLines": {
              "type": "number"
            },
            "afterAutospacing": {
              "type": "boolean"
            },
            "lineRule": {
              "type": "enum",
              "values": [
                "atLeast",
                "auto",
                "exact"
              ]
            }
          }
        },
        "bdr": {
          "type": "object"
        },
        "widowControl": {
          "type": "boolean"
        },
        "keepNext": {
          "type": "boolean"
        },
        "keepLines": {
          "type": "boolean"
        },
        "pageBreakBefore": {
          "type": "boolean"
        },
        "framePr": {
          "type": "object"
        },
        "shd": {
          "type": "object",
          "fields": {
            "val": {
              "type": "string"
            },
            "color": {
              "type": "string"
            },
            "fill": {
              "type": "string"
            }
          }
        },
        "tabs": {
          "type": "array"
        },
        "calloutPr": {
          "type": "object"
        }
      },
      "aliases": {
        "align": "jc",
        "text-align": "jc"
      }
